# Translation uses POST /api/translate on your backend (Khaya key stays on Render only).
# On Vercel, vercel.json rewrites /api/* → your Render API (no env required).
# Override if the API lives elsewhere:
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional: direct browser → Khaya when proxy fails (key is public in the JS bundle).
# VITE_KHAYA_API_KEY=

# Optional: override Khaya endpoint when using direct browser calls
# VITE_KHAYA_TRANSLATE_URL=
