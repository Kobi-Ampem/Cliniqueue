# Server port (default: 3001)
PORT=3001

# Khaya AI / GhanaNLP Translation API
# 1. Sign up at https://translation.ghananlp.org/signup
# 2. Subscribe to a plan (Developer plan = 100 free calls/month)
# 3. Copy your subscription key and paste it below
GHANANLP_API_KEY=your-khaya-api-key-here
GHANANLP_API_URL=https://translation-api.ghananlp.org/v1/translate

# Supabase Database
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the Project URL and anon/public key
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...your-anon-key
